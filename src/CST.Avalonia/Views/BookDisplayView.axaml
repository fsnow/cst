<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:CST.Avalonia.ViewModels"
             xmlns:wv="using:WebViewControl"
             xmlns:converters="using:CST.Avalonia.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="CST.Avalonia.Views.BookDisplayView"
             x:DataType="vm:BookDisplayViewModel"
             Focusable="True">

    <Design.DataContext>
        <vm:BookDisplayViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <!-- Bitmap <Image> content doesn't inherit a Button's disabled foreground, so an image
             button looks identical when disabled. Dim it explicitly so hit-navigation buttons
             visibly grey out at the first/last hit (their commands' CanExecute is false there). -->
        <Style Selector="Button:disabled Image">
            <Setter Property="Opacity" Value="0.35"/>
        </Style>
    </UserControl.Styles>

    <DockPanel>
        <!-- Toolbar (#104): DockPanel pins Float/Dock to the right (always reachable); the tool
             groups live in a WrapPanel so they wrap to a second row instead of clipping off the
             right edge when the window is narrow. Footprint trimmed: no "Script:"/"Chapter:" text
             labels (tooltips instead), no separator bars (spacing instead), narrower Chapter combo. -->
        <DockPanel DockPanel.Dock="Top" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}" MinHeight="40">

            <!-- Window Management (Float/Dock) - pinned right, always visible -->
            <Button DockPanel.Dock="Right"
                    Command="{Binding FloatWindowCommand}"
                    IsVisible="{Binding !IsFloating}"
                    ToolTip.Tip="Open this book in a separate window"
                    Margin="5,0"
                    Padding="8,4"
                    VerticalAlignment="Center">
                <TextBlock Text="↗" FontSize="16" VerticalAlignment="Center"/>
            </Button>
            <Button DockPanel.Dock="Right"
                    Command="{Binding UnfloatWindowCommand}"
                    IsVisible="{Binding IsFloating}"
                    ToolTip.Tip="Move this book back to main window"
                    Margin="5,0"
                    Padding="8,4"
                    VerticalAlignment="Center">
                <TextBlock Text="↙" FontSize="16" VerticalAlignment="Center"/>
            </Button>

            <!-- Tool groups; wrap to a second row instead of clipping when the window is narrow -->
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Script Selector -->
                <ComboBox ItemsSource="{Binding AvailableScripts}"
                          SelectedItem="{Binding BookScript}"
                          MinWidth="120"
                          Margin="5"
                          VerticalAlignment="Center"
                          ToolTip.Tip="Script for displaying Pali text">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Chapter Navigation -->
                <ComboBox ItemsSource="{Binding Chapters}"
                          SelectedItem="{Binding SelectedChapter}"
                          MinWidth="150"
                          MaxWidth="220"
                          Margin="5"
                          VerticalAlignment="Center"
                          IsVisible="{Binding HasChapters}"
                          ToolTip.Tip="Navigate to chapter">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                      TextTrimming="CharacterEllipsis"
                                      MaxWidth="200"
                                      converters:FontHelper.DynamicFontFamily="{Binding $parent[UserControl].DataContext.CurrentScriptFontFamily}"
                                      converters:FontHelper.DynamicFontSize="{Binding $parent[UserControl].DataContext.CurrentScriptFontSize}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Search Navigation (visible when search terms present) -->
                <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center"
                            IsVisible="{Binding HasSearchHighlights}">
                    <Button Command="{Binding FirstHitCommand}" ToolTip.Tip="First search result" Margin="2">
                        <Image Source="avares://CST.Avalonia/Assets/Images/ArrowFirst.png" Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding PreviousHitCommand}" ToolTip.Tip="Previous search result" Margin="2">
                        <Image Source="avares://CST.Avalonia/Assets/Images/ArrowPrevious.png" Width="16" Height="16"/>
                    </Button>
                    <!-- Stable width so the counter's digit count ("9 of 5" -> "10 of 5" -> "100 of 5")
                         can't change the WrapPanel's layout and reflow the buttons to a second row —
                         a taller toolbar shrinks the WebView viewport and can scroll the target hit out
                         of view. Reserve is per-book (sized to TotalHits' digit count), so small
                         searches don't over-pad the toolbar and make a 2nd row more likely. (#196) -->
                    <TextBlock Text="{Binding HitStatusText}" VerticalAlignment="Center" Margin="5,0"
                               TextAlignment="Center"
                               MinWidth="{Binding TotalHits, Converter={x:Static converters:HitCounterWidthConverter.Instance}}"/>
                    <Button Command="{Binding NextHitCommand}" ToolTip.Tip="Next search result" Margin="2">
                        <Image Source="avares://CST.Avalonia/Assets/Images/ArrowNext.png" Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding LastHitCommand}" ToolTip.Tip="Last search result" Margin="2">
                        <Image Source="avares://CST.Avalonia/Assets/Images/ArrowLast.png" Width="16" Height="16"/>
                    </Button>
                </StackPanel>

                <!-- Book Type Navigation (Mula/Atthakatha/Tika) -->
                <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center"
                            IsVisible="{Binding HasLinkedBooks}">
                    <Button Command="{Binding OpenMulaCommand}"
                            IsEnabled="{Binding HasMula}"
                            ToolTip.Tip="Open root text" Margin="2">
                        <TextBlock Text="Mula"/>
                    </Button>
                    <Button Command="{Binding OpenAtthakathaCommand}"
                            IsEnabled="{Binding HasAtthakatha}"
                            ToolTip.Tip="Open commentary" Margin="2">
                        <TextBlock Text="Aṭṭha"/>
                    </Button>
                    <Button Command="{Binding OpenTikaCommand}"
                            IsEnabled="{Binding HasTika}"
                            ToolTip.Tip="Open sub-commentary" Margin="2">
                        <TextBlock Text="Ṭīkā"/>
                    </Button>
                </StackPanel>

                <!-- View Source PDF buttons -->
                <StackPanel Orientation="Horizontal" Margin="5" VerticalAlignment="Center">
                    <Button Command="{Binding ShowSource1957Command}"
                            ToolTip.Tip="View Burmese 1957 edition PDF (Cmd+E)" Margin="2">
                        <TextBlock Text="1957"/>
                    </Button>
                    <Button Command="{Binding ShowSource2010Command}"
                            ToolTip.Tip="View Burmese 2010 edition PDF (Shift+Cmd+E)" Margin="2">
                        <TextBlock Text="2010"/>
                    </Button>
                </StackPanel>

            </WrapPanel>
        </DockPanel>

        <!-- Status Bar -->
        <Grid DockPanel.Dock="Bottom" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}" MinHeight="26">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Page References (VRI, Myanmar, PTS, Thai, Other) -->
            <TextBlock Grid.Column="0" Text="{Binding PageReferencesText}" 
                       VerticalAlignment="Center" Margin="8,0"
                       ToolTip.Tip="Page numbers: VRI=Vipassana Research Institute, Myanmar=Burmese edition, PTS=Pali Text Society, Thai=Thai edition, Other=Miscellaneous editions"/>
            
            <!-- Book Info -->
            <TextBlock Grid.Column="1" Text="{Binding BookInfoText}" 
                       VerticalAlignment="Center" Margin="8,0"
                       converters:FontHelper.DynamicFontFamily="{Binding CurrentScriptFontFamily}"
                       converters:FontHelper.DynamicFontSize="{Binding CurrentScriptFontSize}"/>
            
            <!-- Loading Indicator -->
            <ProgressBar Grid.Column="2" IsIndeterminate="True" 
                         IsVisible="{Binding IsLoading}" 
                         Width="100" Height="16" Margin="8,0"/>
        </Grid>

        <!-- Main Browser Control -->
        <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Panel>
                <!-- WebView Browser -->
                <wv:WebView x:Name="webView" 
                           IsVisible="{Binding IsWebViewAvailable}"
                           Focusable="True"
                           IsTabStop="True"
                           ZIndex="-1000"
                           IsHitTestVisible="True"/>
                
                <!-- Fallback Text Display -->
                <ScrollViewer x:Name="fallbackBrowser"
                              Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                              IsVisible="{Binding !IsWebViewAvailable}">
                    <StackPanel Margin="10">
                        <TextBlock Text="=== FALLBACK TEXT DISPLAY ==="
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="{Binding BookInfoText}"
                                   FontWeight="Bold"
                                   Margin="0,0,0,5"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="{Binding PageStatusText}"
                                   Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="{Binding HtmlContent}"
                                   TextWrapping="Wrap"
                                   FontFamily="Times New Roman"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>
                </ScrollViewer>
            </Panel>
        </Border>
    </DockPanel>
</UserControl>