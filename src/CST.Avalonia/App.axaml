<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CST.Avalonia.App"
             Name="CST Reader"
             xmlns:local="using:CST.Avalonia"
             xmlns:vm="using:CST.Avalonia.ViewModels"
             xmlns:views="using:CST.Avalonia.Views"
             xmlns:dock="using:Dock.Model.Mvvm.Controls"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <!-- ReactiveUI ViewModels are now dockables directly (no Tool/Document wrappers) -->

        <!-- DataTemplate for OpenBookDialogViewModel (ReactiveTool) -> OpenBookPanel -->
        <DataTemplate DataType="{x:Type vm:OpenBookDialogViewModel}">
            <views:OpenBookPanel />
        </DataTemplate>

        <!-- DataTemplate for SearchViewModel (ReactiveTool) -> SearchPanel -->
        <DataTemplate DataType="{x:Type vm:SearchViewModel}">
            <views:SearchPanel />
        </DataTemplate>

        <!-- DataTemplate for DictionaryViewModel (ReactiveTool) -> DictionaryPanel -->
        <DataTemplate DataType="{x:Type vm:DictionaryViewModel}">
            <views:DictionaryPanel />
        </DataTemplate>

        <!-- DataTemplate for BookDisplayViewModel (ReactiveDocument) -> BookDisplayView -->
        <DataTemplate DataType="{x:Type vm:BookDisplayViewModel}">
            <views:BookDisplayView />
        </DataTemplate>

        <!-- DataTemplate for PdfDisplayViewModel (ReactiveDocument) -> PdfDisplayView -->
        <DataTemplate DataType="{x:Type vm:PdfDisplayViewModel}">
            <views:PdfDisplayView />
        </DataTemplate>

        <!-- DataTemplate for WelcomeViewModel (ReactiveDocument) -> Welcome screen with WebView -->
        <DataTemplate DataType="{x:Type vm:WelcomeViewModel}">
            <views:WelcomeView />
        </DataTemplate>

    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- Light-mode surface hierarchy (#102): a SUBTLE grey "chrome" tone (toolbars,
                     left tool dock, tree, gutters) against white "content" surfaces (reading pane,
                     cards) - matching the gentle VS Code "Light 2026" aesthetic, not a high-contrast
                     ladder. Chrome #F6F6F9 vs content #FFFFFF ~= a 9-level step. Dark mode unchanged
                     (empty Dark dict below). -->
                <ResourceDictionary x:Key="Light">
                    <!-- Chrome: window/page bg, dock gutters, book tree, toolbars, status bars, nav -->
                    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#F6F6F9"/>
                    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="#F6F6F9"/>
                    <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#F6F6F9"/>
                    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="#F6F6F9"/>
                    <!-- Content surfaces: reading pane fallback, cards, search results -->
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#FFFFFF"/>
                    <!-- Subtle border so inset content edges read against the grey -->
                    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="#E6E6EC"/>
                </ResourceDictionary>
                <!-- Dark mode unchanged: inherit Fluent dark defaults -->
                <ResourceDictionary x:Key="Dark"/>
            </ResourceDictionary.ThemeDictionaries>

            <!-- ControlRecycling for view caching - preserves scroll position and state when switching tabs -->
            <!-- Using instance-based caching (default) - same ViewModel instance = same cached View -->
            <ControlRecycling x:Key="ControlRecyclingKey" />
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Dock.Avalonia.Themes.Fluent/DockFluentTheme.axaml" />
        <StyleInclude Source="avares://CST.Avalonia/Styles/DockStyles.axaml" />

        <!-- Attach ControlRecycling to all DockControl instances -->
        <Style Selector="DockControl">
            <Setter Property="(ControlRecyclingDataTemplate.ControlRecycling)"
                    Value="{StaticResource ControlRecyclingKey}" />
        </Style>

        <!-- Tab font styling: Each tab should use its book's script font -->
        <!-- This is complex due to the dock system structure - leaving for future enhancement -->
        <!-- Current implementation covers: search results, book tree, chapter dropdown, status bar -->
    </Application.Styles>
    
    <!-- Native Menu for macOS - Application level (goes into CST Reader app menu) -->
    <NativeMenu.Menu>
        <NativeMenu>
            <!-- Preferences in app menu following macOS convention -->
            <NativeMenuItem Header="Preferences..." Gesture="Cmd+OemComma" />
        </NativeMenu>
    </NativeMenu.Menu>
</Application>